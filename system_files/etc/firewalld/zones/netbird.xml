<?xml version="1.0" encoding="utf-8"?>
<zone>
  <short>Netbird</short>
  <description>Netbird VPN tunnel zone. Allows Cockpit, SSH, HTTP, and HTTPS over the Netbird interface.</description>
  <interface name="wt0"/>
  <service name="cockpit"/>
  <service name="ssh"/>
  <!-- Caddy reverse proxy service ports (all HTTPS via internal CA) -->
  <port protocol="tcp" port="8443"/>
  <port protocol="tcp" port="8444"/>
  <port protocol="tcp" port="8445"/>
  <port protocol="tcp" port="9443"/>
</zone>
